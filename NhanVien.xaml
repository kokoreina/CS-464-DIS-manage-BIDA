<Window x:Class="Dash_boardsBIDA.NhanVien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Nhân viên"
        Height="720" Width="1250"
        Background="#EFEFEF"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- List item wrapper -->
        <Style x:Key="EmployeeCardStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Basic textbox underline -->
        <Style x:Key="UnderlineTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#C9C9C9"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,4,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <Style x:Key="UnderlineComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#C9C9C9"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,2,0,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3E6B5A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="DangerLinkBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E74C3C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>

            <Grid Margin="18">
                <TextBlock Text="Nhân viên"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUserName}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0"/>

                    <TextBlock Text="Thoát"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Cursor="Hand"
                               Foreground="#333"
                               MouseDown="Exit_MouseDown"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SIDEBAR (để trống nếu bạn chưa merge sidebar main) -->
        <Grid Grid.RowSpan="2" Background="#3E6B5A">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Billiard 4 Life"
                           Foreground="White"
                           FontSize="20"
                           Margin="20"
                           FontWeight="Bold"/>

                <Button Content="👤  Nhân viên"
                        Margin="12,6"
                        Height="44"
                        Background="#4E8B7A"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalContentAlignment="Left"
                        Padding="14,0"/>

                <!-- bạn có thể gắn Click để quay lại MainWindow sau -->
                <Button Content="←  Quay lại"
                        Margin="12,6"
                        Height="44"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalContentAlignment="Left"
                        Padding="14,0"
                        Click="Back_Click"/>
            </StackPanel>

            <Button Grid.Row="1"
                    Content="🚪  Đăng xuất"
                    Margin="12"
                    Height="44"
                    Background="#2F5648"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Logout_Click"/>
        </Grid>

        <!-- ================= CENTER CONTENT ================= -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="22,14,18,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search + actions -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="White"
                        CornerRadius="18"
                        BorderBrush="#EEE"
                        BorderThickness="1"
                        Height="42"
                        Width="320"
                        VerticalAlignment="Center">
                    <Grid Margin="10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="🔍"
                                   VerticalAlignment="Center"
                                   Foreground="#999"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Foreground="#666"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="+ Thêm mới"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryBtn}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Xóa"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource DangerLinkBtn}"
                            Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- header row -->
            <Grid Grid.Row="1" Margin="8,0,8,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="NHÂN VIÊN" FontSize="11" FontWeight="Bold" Foreground="#95A5A6"/>
                <TextBlock Text="CHỨC VỤ" Grid.Column="1" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" HorizontalAlignment="Center"/>
                <TextBlock Text="TRẠNG THÁI" Grid.Column="2" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" HorizontalAlignment="Right"/>
            </Grid>

            <!-- list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ListBox ItemsSource="{Binding FilteredEmployees}"
                         SelectedItem="{Binding SelectedEmployee}"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource EmployeeCardStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemCard"
                                    Background="White"
                                    CornerRadius="14"
                                    Padding="18,14"
                                    BorderBrush="Transparent"
                                    BorderThickness="1.5">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="42" Height="42"
                                                Background="#F0F4F3"
                                                CornerRadius="12"
                                                Margin="0,0,14,0">
                                            <TextBlock Text="👤"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       FontSize="18"/>
                                        </Border>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TenNV}"
                                                       FontWeight="Bold"
                                                       FontSize="15"
                                                       Foreground="#2C3E50"/>
                                            <TextBlock Text="{Binding ID}"
                                                       FontSize="12"
                                                       Foreground="#BDC3C7"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding VaiTro}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="#34495E"/>

                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="#2ECC71" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding TrangThai}"
                                                   Foreground="#2ECC71"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="ItemCard" Property="BorderBrush" Value="#3E6B5A"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <!-- ================= RIGHT DETAIL PANEL ================= -->
        <Border Grid.Row="1"
                Grid.Column="2"
                Margin="18,14,22,14"
                Background="White"
                CornerRadius="18"
                Padding="18"
                BorderBrush="#E7E7E7"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.07"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Thông tin nhân viên"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               Margin="0,0,0,12"/>

                    <!-- ID + Họ tên -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="ID" FontSize="12" Foreground="#777"/>
                            <TextBlock Text="{Binding SelectedEmployee.ID}"
                                       FontWeight="SemiBold"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Họ tên" FontSize="12" Foreground="#777"/>
                            <TextBox Text="{Binding SelectedEmployee.TenNV, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource UnderlineTextBox}"
                                     Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Chức vụ + Loại NV -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Chức vụ" FontSize="12" Foreground="#777"/>
                            <ComboBox SelectedValue="{Binding SelectedEmployee.VaiTro, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Content"
                                      Style="{StaticResource UnderlineComboBox}">
                                <ComboBoxItem Content="Quản lý"/>
                                <ComboBoxItem Content="Nhân viên"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Loại nhân viên" FontSize="12" Foreground="#777"/>
                            <ComboBox SelectedValue="{Binding SelectedEmployee.LoaiNV, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Content"
                                      Style="{StaticResource UnderlineComboBox}">
                                <ComboBoxItem Content="Full-time"/>
                                <ComboBoxItem Content="Part-time"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Địa chỉ + SĐT -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Địa chỉ" FontSize="12" Foreground="#777"/>
                            <TextBox Text="{Binding SelectedEmployee.DiaChi, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource UnderlineTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="SĐT" FontSize="12" Foreground="#777"/>
                            <TextBox Text="{Binding SelectedEmployee.SDT, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource UnderlineTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Ngày sinh + Ngày vào làm -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Ngày sinh" FontSize="12" Foreground="#777"/>
                            <DatePicker SelectedDate="{Binding SelectedEmployee.NgaySinh, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Ngày vào làm" FontSize="12" Foreground="#777"/>
                            <DatePicker SelectedDate="{Binding SelectedEmployee.NgayVaoLam, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Tài khoản + Mật khẩu -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Tài khoản" FontSize="12" Foreground="#777"/>
                            <TextBox Text="{Binding SelectedEmployee.TaiKhoan, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource UnderlineTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Mật khẩu" FontSize="12" Foreground="#777"/>
                            <TextBox Text="{Binding SelectedEmployee.MatKhau, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource UnderlineTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Lưu thay đổi"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryBtn}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>