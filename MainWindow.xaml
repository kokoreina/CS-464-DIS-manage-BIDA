<Window x:Class="Dash_boardsBIDA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Billiard 4 Life"
        Height="720"
        Width="1250"
        Background="#EFEFEF"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FoodCard" TargetType="Border">
            <Setter Property="Width" Value="170"/>
            <Setter Property="Height" Value="220"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="OrderBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3E6B5A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="SideMenuBtn" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="15,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Column="1" Grid.ColumnSpan="2" Background="White">
            <Grid Margin="15">
                <TextBlock Text="Menu" FontSize="24" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="TxtUser" Text="User" Margin="10,0"/>
                    <TextBlock Text="⏻" FontSize="18"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SIDEBAR -->
        <Grid Grid.RowSpan="2" Background="#3E6B5A">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Billiard 4 Life"
                           Foreground="White"
                           FontSize="20"
                           Margin="20"
                           FontWeight="Bold"/>

                <Button Content="🏠  Menu" Style="{StaticResource SideMenuBtn}" Click="OpenMenu_Click"/>
                <Button Content="🎱  Tình Trạng Bàn" Style="{StaticResource SideMenuBtn}" Click="OpenTable_Click"/>

                <!-- THÊM 2 NÚT NÀY -->
                <Button Content="🧾  Hóa đơn" Style="{StaticResource SideMenuBtn}" Click="OpenHoaDon_Click"/>
                <Button Content="📊  Thống kê" Style="{StaticResource SideMenuBtn}" Click="OpenThongKe_Click"/>
                <Button Content="👤  Nhân viên"
 Style="{StaticResource SideMenuBtn}"
        Click="OpenEmployeePage_Click"/>

            </StackPanel>

            <Button Grid.Row="1"
                    Content="🚪  Đăng xuất"
                    Margin="15"
                    Height="45"
                    Background="#2F5648"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Logout_Click"/>
        </Grid>

        <!-- MENU PANEL -->
        <Grid x:Name="MenuPanel" Grid.Column="1" Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#DDD" BorderThickness="1" Padding="8">
                    <DockPanel>
                        <TextBlock Text="🔍" FontSize="16" Margin="5" VerticalAlignment="Center"/>
                        <TextBox x:Name="SearchBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="14"
                                 VerticalAlignment="Center"
                                 Text="Tìm kiếm món ăn"
                                 GotFocus="SearchBox_GotFocus"
                                 LostFocus="SearchBox_LostFocus"/>
                    </DockPanel>
                </Border>

                <Button Grid.Column="1"
                        Content="➕ Thêm món"
                        Margin="10,0"
                        Background="#3E6B5A"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Width="120"
                        Height="40"
                        Click="BtnThemMon_Click"/>

                <Button Grid.Column="2"
                        Content="← Quay lại"
                        Background="#E5E5E5"
                        Foreground="Black"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BackToTable_Click"/>
            </Grid>

            <ScrollViewer Grid.Row="1">
                <WrapPanel x:Name="FoodWrapPanel"/>
            </ScrollViewer>
        </Grid>

        <!-- TABLE PANEL (UserControl) -->
        <ContentControl x:Name="MainContent"
                        Grid.Column="1"
                        Grid.Row="1"
                        Margin="10"
                        Visibility="Collapsed"/>

        <!-- ORDER PANEL -->
        <Border Grid.Column="2" Grid.Row="1" Background="#F6F6F6" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#3E6B5A" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="NEW ORDER" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,5">
                            <TextBlock Text="ĐANG CHỌN: " Foreground="#A5D6A7" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtSelectedTable"
                                       Text="Chưa chọn bàn"
                                       Foreground="#FFD700"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Margin="0,15,0,10" Background="White"
                        CornerRadius="10" BorderBrush="#E2E2E2" BorderThickness="1" Padding="5">
                    <ListView x:Name="OrderList" BorderThickness="0" Background="Transparent">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Món" Width="150" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="SL" Width="45" DisplayMemberBinding="{Binding Quantity}"/>
                                <GridViewColumn Header="Giá (VND)" Width="110"
                                                DisplayMemberBinding="{Binding Total, StringFormat='{}{0:N0}'}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <StackPanel Grid.Row="2">
                    <Grid Margin="0,5,0,15">
                        <TextBlock Text="TỔNG CỘNG" FontSize="16" FontWeight="Bold" Foreground="#666"/>
                        <TextBlock x:Name="TotalText"
                                   Text="0 VND"
                                   HorizontalAlignment="Right"
                                   FontSize="24"
                                   FontWeight="ExtraBold"
                                   Foreground="#3E6B5A"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="Xóa bàn"
                                Margin="0,0,5,0"
                                Padding="10"
                                Background="#FADBD8"
                                Foreground="#E74C3C"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="BtnClearTable_Click"/>

                        <Button Grid.Column="1"
                                Content="THANH TOÁN"
                                FontWeight="Bold"
                                Padding="10"
                                Background="#3E6B5A"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnThanhToan_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>