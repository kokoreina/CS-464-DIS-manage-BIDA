<Window x:Class="Dash_boardsBIDA.AddFoodWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm món"
        Height="550"
        Width="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#80000000"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid>

        <!-- FORM -->
        <Border Width="700"
                Height="450"
                Background="White"
                CornerRadius="10"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="3"
                                  Opacity="0.5"/>
            </Border.Effect>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <!-- TITLE -->
                <TextBlock Text="THÊM MÓN MỚI"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <!-- CONTENT -->
                <Grid Grid.Row="1" Margin="0,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- IMAGE -->
                    <Border Background="#EEE"
                            CornerRadius="8">

                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">

                            <TextBlock Text="Ảnh món"
                                       Margin="0,10"
                                       HorizontalAlignment="Center"/>

                            <Button Content="Chọn ảnh"
                                    Width="120"
                                    Height="35"/>
                        </StackPanel>
                    </Border>

                    <!-- INPUT -->
                    <StackPanel Grid.Column="1"
                                Margin="20,0">

                        <TextBlock Text="Tên món"/>
                        <TextBox x:Name="txtTenMon"
                                 Height="35"
                                 Margin="0,5"/>

                        <TextBlock Text="Giá"/>
                        <TextBox x:Name="txtGia"
                                 Height="35"
                                 Margin="0,5"/>

                    </StackPanel>

                </Grid>

                <!-- BUTTON -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Hủy"
                            Width="100"
                            Height="35"
                            Margin="5"
                            Click="BtnClose_Click"/>

                    <Button Content="Thêm món"
                            Width="120"
                            Height="35"
                            Background="#3F6F5A"
                            Foreground="White"
                            Margin="5"
                            Click="BtnAdd_Click"/>

                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Window>