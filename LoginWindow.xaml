<Window x:Class="Dash_boardsBIDA.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập"
        Width="520" Height="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#F4F6F8" Margin="20">
        <Border Background="White" CornerRadius="10" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ĐĂNG NHẬP" FontSize="22" FontWeight="Bold" Foreground="#3E6B5A"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Email" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtEmail" Height="35" Padding="10" />
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Mật khẩu" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="TxtPass" Height="35" Padding="10"/>
                </StackPanel>

                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Thoát" Width="90" Height="35" Margin="0,0,10,0" Click="BtnExit_Click"/>
                    <Button Content="Đăng nhập" Width="110" Height="35"
                            Background="#3E6B5A" Foreground="White"
                            BorderThickness="0" Click="BtnLogin_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>