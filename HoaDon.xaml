<UserControl x:Class="Dash_boardsBIDA.HoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F4F6F8">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="White" CornerRadius="12" Padding="14" BorderBrush="#E6E6E6" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="LỊCH SỬ HÓA ĐƠN" FontSize="20" FontWeight="Bold" Foreground="#2F5648"/>
                    <TextBlock Text="Xem danh sách và chi tiết hóa đơn đã thanh toán" Foreground="#777" Margin="0,4,0,0"/>
                </StackPanel>

                <TextBox x:Name="TxtSearchInvoice"
                         Grid.Column="1"
                         Height="36"
                         Margin="10,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         Padding="10,0"
                         Text="Tìm theo mã / bàn / user..."
                         Foreground="#666"/>

                <Button x:Name="BtnRefresh"
                        Grid.Column="2"
                        Height="36"
                        Content="Làm mới"
                        Background="#3E6B5A"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: LIST INVOICES -->
            <Border Background="White" CornerRadius="12" Padding="10" BorderBrush="#E6E6E6" BorderThickness="1" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Danh sách hóa đơn" FontWeight="Bold" FontSize="15" Foreground="#333" Margin="6,2,0,8"/>

                    <DataGrid x:Name="DgInvoices"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="40"
                              ColumnHeaderHeight="36"
                              BorderThickness="0"
                              Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã" Width="110" Binding="{Binding InvoiceId}"/>
                            <DataGridTextColumn Header="Thời gian" Width="160" Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"/>
                            <DataGridTextColumn Header="Bàn" Width="90" Binding="{Binding TableName}"/>
                            <DataGridTextColumn Header="Giờ" Width="110" Binding="{Binding TimeMoney, StringFormat={}{0:N0}}"/>
                            <DataGridTextColumn Header="Đồ ăn" Width="110" Binding="{Binding FoodMoney, StringFormat={}{0:N0}}"/>
                            <DataGridTextColumn Header="Tổng" Width="*" Binding="{Binding TotalMoney, StringFormat={}{0:N0}}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- RIGHT: INVOICE DETAIL -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="14" BorderBrush="#E6E6E6" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Chi tiết hóa đơn" FontWeight="Bold" FontSize="15" Foreground="#333"/>

                    <!-- INFO -->
                    <Grid Grid.Row="1" Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Mã hóa đơn" Foreground="#777"/>
                            <TextBlock x:Name="TxtInvId" Text="---" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Thời gian" Foreground="#777"/>
                            <TextBlock x:Name="TxtInvTime" Text="---" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Bàn" Foreground="#777"/>
                            <TextBlock x:Name="TxtInvTable" Text="---" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,10,0,0">
                            <TextBlock Text="User" Foreground="#777"/>
                            <TextBlock x:Name="TxtInvUser" Text="---" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Grid>

                    <!-- ITEMS -->
                    <Border Grid.Row="2" CornerRadius="10" BorderBrush="#EEE" BorderThickness="1" Padding="6">
                        <DataGrid x:Name="DgInvoiceItems"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="38"
                                  ColumnHeaderHeight="34"
                                  BorderThickness="0"
                                  Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Món" Width="*" Binding="{Binding Name}"/>
                                <DataGridTextColumn Header="SL" Width="60" Binding="{Binding Quantity}"/>
                                <DataGridTextColumn Header="Đơn giá" Width="110" Binding="{Binding Price, StringFormat={}{0:N0}}"/>
                                <DataGridTextColumn Header="Thành tiền" Width="130" Binding="{Binding Total, StringFormat={}{0:N0}}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- TOTALS -->
                    <Border Grid.Row="3" Margin="0,10,0,0" Background="#F6F6F6" CornerRadius="10" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tiền giờ" Foreground="#555" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtInvTimeMoney" Grid.Column="1" Text="0" FontWeight="Bold"/>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tiền đồ ăn/nước" Foreground="#555" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtInvFoodMoney" Grid.Column="1" Text="0" FontWeight="Bold"/>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TỔNG CỘNG" Foreground="#2F5648" FontWeight="Bold" FontSize="16"/>
                                <TextBlock x:Name="TxtInvTotal" Grid.Column="1" Text="0" Foreground="#2F5648" FontWeight="ExtraBold" FontSize="18"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>