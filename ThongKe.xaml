<UserControl x:Class="Dash_boardsBIDA.ThongKe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F8">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" CornerRadius="12" Padding="14" BorderBrush="#E2E2E2" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊" FontSize="20" Margin="0,0,10,0"/>
                    <TextBlock Text="THỐNG KÊ DOANH THU (THEO THÁNG)"
                               FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <DatePicker x:Name="DpMonth"
                            Grid.Column="1"
                            Width="160"
                            Margin="10,0"
                            SelectedDateFormat="Short"/>

                <Button x:Name="BtnApply"
                        Grid.Column="2"
                        Content="Áp dụng"
                        Padding="14,8"
                        Background="#3E6B5A"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Summary cards -->
        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,10,0" BorderBrush="#E2E2E2" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⏱️ Doanh thu TIỀN GIỜ" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock x:Name="TxtMonthTime" Text="0" FontSize="26" FontWeight="ExtraBold" Foreground="#3E6B5A" Margin="0,6,0,0"/>
                    <TextBlock Text="VND" Opacity="0.6"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="14" Margin="0,0,10,0" BorderBrush="#E2E2E2" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="🥤 Doanh thu ĐỒ ĂN / NƯỚC" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock x:Name="TxtMonthFood" Text="0" FontSize="26" FontWeight="ExtraBold" Foreground="#3E6B5A" Margin="0,6,0,0"/>
                    <TextBlock Text="VND" Opacity="0.6"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="14" BorderBrush="#E2E2E2" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💰 TỔNG DOANH THU" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock x:Name="TxtMonthTotal" Text="0" FontSize="26" FontWeight="ExtraBold" Foreground="#3E6B5A" Margin="0,6,0,0"/>
                    <TextBlock Text="VND" Opacity="0.6"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Daily table -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="10" BorderBrush="#E2E2E2" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Chi tiết theo ngày"
                           FontSize="16" FontWeight="Bold" Margin="6,4,0,8"/>

                <DataGrid x:Name="DgDaily"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          GridLinesVisibility="None">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="*"/>
                        <DataGridTextColumn Header="Tiền giờ" Binding="{Binding TimeMoney, StringFormat={}{0:N0}}" Width="*"/>
                        <DataGridTextColumn Header="Tiền đồ ăn/nước" Binding="{Binding FoodMoney, StringFormat={}{0:N0}}" Width="*"/>
                        <DataGridTextColumn Header="Tổng" Binding="{Binding TotalMoney, StringFormat={}{0:N0}}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</UserControl>